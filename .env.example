# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.

# ── Ollama AI ──────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://10.0.0.20:11434
OLLAMA_MODEL=llava-phi3

# ── Google Drive ───────────────────────────────────────────────────────────────
# Use GDRIVE_FOLDER_ID (opaque Drive ID) OR GDRIVE_FOLDER_NAME (human name).
# GDRIVE_FOLDER_ID takes priority when both are set.
GDRIVE_FOLDER_ID=
GDRIVE_FOLDER_NAME=Lika_ETSY
GDRIVE_CREDENTIALS_FILE=config/gdrive_credentials.json

# ── Currency ───────────────────────────────────────────────────────────────────
ILS_TO_USD_RATIO=0.80

# ── GitHub Pages ───────────────────────────────────────────────────────────────
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO=olegsher-ds-2025/LikaVal
GITHUB_PAGES_BRANCH=gh-pages

# ── Etsy ───────────────────────────────────────────────────────────────────────
ETSY_API_KEY=your_etsy_api_key
ETSY_SHOP_ID=your_etsy_shop_id

# ── Facebook ───────────────────────────────────────────────────────────────────
FACEBOOK_PAGE_ID=your_facebook_page_id
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Cron expression for the daily pipeline run (default: 2:00 AM)
PUBLISH_SCHEDULE=0 2 * * *
