# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.

# ── Ollama AI ──────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://192.168.1.100:11434
OLLAMA_MODEL=llava

# ── Google Drive ───────────────────────────────────────────────────────────────
GDRIVE_FOLDER_ID=your_google_drive_folder_id_here
GDRIVE_CREDENTIALS_FILE=config/gdrive_credentials.json

# ── Currency ───────────────────────────────────────────────────────────────────
ILS_TO_USD_RATIO=0.80

# ── GitHub Pages ───────────────────────────────────────────────────────────────
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO=olegsher-ds-2025/LikaVal
GITHUB_PAGES_BRANCH=gh-pages

# ── Etsy ───────────────────────────────────────────────────────────────────────
ETSY_API_KEY=your_etsy_api_key
ETSY_SHOP_ID=your_etsy_shop_id

# ── Facebook ───────────────────────────────────────────────────────────────────
FACEBOOK_PAGE_ID=your_facebook_page_id
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Cron expression for the daily pipeline run (default: 2:00 AM)
PUBLISH_SCHEDULE=0 2 * * *
